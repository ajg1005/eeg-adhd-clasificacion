# Copia este fichero como `.env` y rellena al menos POSTGRES_PASSWORD antes de
# lanzar `docker compose up`.

# Base de datos PostgreSQL.
POSTGRES_DB=eeg_adhd
POSTGRES_USER=eeg_app
POSTGRES_PASSWORD=cambiame

# Opcional: URL del backend tal y como la ve el navegador (Vite la inyecta).
# Por defecto http://127.0.0.1:8000 (utiliza el puerto publicado por compose).
# VITE_API_BASE_URL=http://localhost:8000

# Opcional: Redis local al ejecutar backend y worker fuera de Docker.
# Docker Compose utiliza automaticamente el servicio interno redis.
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1
